# Plantilla de variables de entorno — copiar a .env y rellenar.
# NO subir el .env real al repositorio (contiene secretos).

# ─── Servidor ───────────────────────────────────────────────
PORT=4000

# ─── Base de datos MySQL ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=natureza_db

# ─── JWT (cadena larga y aleatoria, mínimo 32 caracteres) ───
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria

# ─── PayPal sandbox (https://developer.paypal.com) ──────────
PAYPAL_CLIENT_ID=tu_client_id
PAYPAL_CLIENT_SECRET=tu_client_secret
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# ─── Frontend ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200

# ─── Email (Gmail SMTP, App Password de 16 caracteres) ──────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=app_password_16_chars
EMAIL_FROM="Natureza Tienda" <tucorreo@gmail.com>
EMAIL_ADMIN=tucorreo@gmail.com
